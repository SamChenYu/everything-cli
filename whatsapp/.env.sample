# No credentials required — WhatsApp Web uses QR code login via the browser.
# A session file (.whatsapp-session) is saved locally after first login to avoid re-scanning.

# WhatsApp Web DOM Selectors
# These selectors may change when WhatsApp updates their web interface
# Update them if the app stops working after a WhatsApp update

# Chat list container
WA_CHAT_LIST_SELECTOR=[aria-label="Chat list"]

# Individual chat row in chat list
WA_CHAT_ROW_SELECTOR=div[role="row"]

# Message container (has metadata attribute with time, date, and sender)
WA_MESSAGE_CONTAINER_SELECTOR=[data-pre-plain-text]

# Attribute name on message container holding "[time, date] sender: " metadata
WA_MESSAGE_META_ATTR=data-pre-plain-text

# Message text selector
WA_MESSAGE_TEXT_SELECTOR=span[data-testid="selectable-text"]

# Outgoing message ancestor selector (used to detect "from me")
WA_MESSAGE_OUTGOING_SELECTOR=.message-out

# Data attribute on message ancestor holding the message ID (fallback for outgoing detection)
WA_MESSAGE_OUTGOING_DATA_ATTR=data-id

# Prefix in the data attribute value that indicates an outgoing message
WA_MESSAGE_OUTGOING_DATA_PREFIX=true_

# QR code selector
WA_QR_CODE_SELECTOR=[data-testid="qrcode"]

# Message input box selector (Lexical editor)
WA_INPUT_BOX_SELECTOR=div[role="textbox"][data-lexical-editor="true"][aria-placeholder="Type a message"]

# Send button selector (aria-label is locale-dependent)
WA_SEND_BUTTON_SELECTOR=[aria-label="Send"]
